{
  "space": {
    "$type": "dimension",
    "$description": "4/8pt grid spacing scale.",
    "0": { "$value": { "value": 0,  "unit": "px" } },
    "1": { "$value": { "value": 4,  "unit": "px" } },
    "2": { "$value": { "value": 8,  "unit": "px" } },
    "3": { "$value": { "value": 12, "unit": "px" } },
    "4": { "$value": { "value": 16, "unit": "px" } },
    "6": { "$value": { "value": 24, "unit": "px" } },
    "8": { "$value": { "value": 32, "unit": "px" } },
    "12": { "$value": { "value": 48, "unit": "px" } },
    "16": { "$value": { "value": 64, "unit": "px" } }
  },
  "radius": {
    "$type": "dimension",
    "$description": "Material 3 corner-radius scale.",
    "xs":   { "$value": { "value": 4,    "unit": "px" } },
    "sm":   { "$value": { "value": 8,    "unit": "px" } },
    "md":   { "$value": { "value": 12,   "unit": "px" } },
    "lg":   { "$value": { "value": 16,   "unit": "px" } },
    "xl":   { "$value": { "value": 24,   "unit": "px" } },
    "2xl":  { "$value": { "value": 32,   "unit": "px" } },
    "full": { "$value": { "value": 9999, "unit": "px" } }
  },
  "size": {
    "$type": "dimension",
    "$description": "Control sizing.",
    "touch-min-ios":     { "$value": { "value": 44, "unit": "px" }, "$description": "Apple HIG minimum target." },
    "touch-min-android": { "$value": { "value": 48, "unit": "px" }, "$description": "Material minimum target." }
  }
}
