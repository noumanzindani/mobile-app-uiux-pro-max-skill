    "react-native": "examples/checkout/react-native",
    "swiftui": "examples/checkout/swiftui",
    "jetpack-compose": "examples/checkout/jetpack-compose"
  },
  "baseline": {
    "flutter": "eval/baselines/checkout/flutter",
    "react-native": "eval/baselines/checkout/react-native"
  }
}
